{
	"name": "gmart-portfolio",
	"compatibility_date": "2025-10-08",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./dist/_worker.js/index.js",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"routes": [
    {
      "pattern": "portfolio.garrettmartin.xyz",
      "custom_domain": true
    }
  ]
}
